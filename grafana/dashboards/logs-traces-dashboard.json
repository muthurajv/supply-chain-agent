{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Logs (Loki)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "logs", "name": "Logs", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "title": "Supply Chain Agent — Logs & Traces",
  "uid": "supply-chain-logs-traces",
  "description": "HTTP request stream, policy decisions, LLM call logs, errors, and per-scope activity — all via Loki stream labels (no | json pipeline).",
  "tags": ["supply-chain", "logs", "traces"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "hide": 2,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Log Stream",
      "description": "All inbound API requests. Stream label http_route is set by FastAPI auto-instrumentation.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", http_route=~\".+\"}",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "title": "Policy Decision Log Stream",
      "description": "Structured audit log from the Policy agent — every approval decision in order.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", scope_name=\"supply_chain_agent.policy\"}",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Call Log Stream",
      "description": "One log record per LLM invocation — agent name, model, input and output token counts.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", scope_name=\"supply_chain_agent.llm\"}",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Log Stream",
      "description": "All ERROR-level logs across all agents and tools.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", severity_text=\"ERROR\"}",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "title": "Log Volume by Severity",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "ERROR"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "WARN"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "INFO"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (severity_text) (count_over_time({service_name=\"supply-chain-agent\"} [$__interval]))",
          "legendFormat": "{{severity_text}}",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "title": "Activity by Agent Scope",
      "description": "Log volume per agent scope — which agents are most active.",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (scope_name) (count_over_time({service_name=\"supply-chain-agent\", scope_name=~\"supply_chain_agent\\\\..+\"} [$__interval]))",
          "legendFormat": "{{scope_name}}",
          "refId": "A",
          "queryType": "range"
        }
      ]
    }
  ]
}
