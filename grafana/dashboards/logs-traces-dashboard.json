{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Logs (Loki)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "Grafana Cloud Traces (Tempo)",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0"},
    {"type": "panel", "id": "logs", "name": "Logs", "version": ""},
    {"type": "panel", "id": "traces", "name": "Traces", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "title": "Supply Chain Agent — Logs & Traces",
  "uid": "supply-chain-logs-traces",
  "description": "Correlated Loki logs and Tempo traces. Click a trace_id in a log line to open the full trace in Tempo.",
  "tags": ["supply-chain", "logs", "traces"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "hide": 2,
        "current": {}
      },
      {
        "name": "DS_TEMPO",
        "type": "datasource",
        "pluginId": "tempo",
        "query": "tempo",
        "hide": 2,
        "current": {}
      },
      {
        "name": "agent",
        "label": "Agent",
        "type": "custom",
        "query": "all,inventory,forecast,procurement,policy,knowledge,analytics",
        "current": {"text": "all", "value": "all"},
        "hide": 0,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Log Stream",
      "description": "Each log line carries otelTraceID — click to jump to the full Tempo trace.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\"} | json | http_route != \"\"",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "title": "Policy Decision Log Stream",
      "description": "Structured audit log from the Policy agent — every approval decision in order.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Log Stream",
      "description": "All ERROR-level logs across all agents and tools.",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\"} | json | level=~\"(?i)error\"",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "title": "Trace Search — Policy Agent Errors",
      "description": "TraceQL search for policy agent spans with error status. Click a row to open the full trace.",
      "type": "traces",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
      "options": {},
      "targets": [
        {
          "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
          "queryType": "traceql",
          "query": "{span.agent.name=\"policy\" && status=error}",
          "refId": "A",
          "limit": 20
        }
      ]
    },
    {
      "id": 5,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 26},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "warn"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "info"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (level) (rate({service_name=\"supply-chain-agent\"} | json | level != \"\" [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "title": "Log Count by Agent",
      "description": "Activity heatmap — which agents are logging most often.",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 26},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (agent_name) (rate({service_name=\"supply-chain-agent\", agent_name=~\".+\"} | json [$__interval]))",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "queryType": "range"
        }
      ]
    }
  ]
}
