{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Mimir",
      "description": "Grafana Cloud Metrics (Mimir)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Logs (Loki)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""}
  ],
  "title": "Supply Chain Agent — Operational",
  "uid": "supply-chain-operational",
  "description": "Request rates, latency, LLM spend, tool health, and active runs (CLAUDE.md §12.1)",
  "tags": ["supply-chain", "operational"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "hide": 2,
        "current": {}
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "hide": 2,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate per Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{job=\"supply-chain-agent\"}[$__rate_interval]))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p50 / p95 / p99 Latency — /chat",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"supply-chain-agent\",http_target=\"/chat\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"supply-chain-agent\",http_target=\"/chat\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"supply-chain-agent\",http_target=\"/chat\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "alert": {
        "name": "p95 /chat latency > 12s",
        "conditions": [
          {
            "evaluator": {"params": [12], "type": "gt"},
            "operator": {"type": "and"},
            "query": {"params": ["B", "5m", "now"]},
            "reducer": {"params": [], "type": "last"},
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data"
      }
    },
    {
      "id": 3,
      "title": "LLM Token Spend per Agent (24 h)",
      "description": "Counts log records containing LLM calls per agent. Install opentelemetry-instrumentation-openai-v2 for exact token counts.",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"orientation": "vertical", "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (scope_name) (count_over_time({service_name=\"supply-chain-agent\", scope_name=~\"supply_chain_agent\\\\..+\"} [24h]))",
          "legendFormat": "{{scope_name}}",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tool Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.02},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum(rate({service_name=\"supply-chain-agent\", severity_text=\"ERROR\"} [$__interval])) / sum(rate({service_name=\"supply-chain-agent\"} [$__interval]))",
          "legendFormat": "error rate",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active LangGraph Runs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(langgraph_active_runs{job=\"supply-chain-agent\"})",
          "legendFormat": "In-flight",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Approval Queue Depth",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 20},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "approval_queue_depth{job=\"supply-chain-agent\"}",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ],
      "alert": {
        "name": "Approval queue depth > 50",
        "conditions": [
          {
            "evaluator": {"params": [50], "type": "gt"},
            "operator": {"type": "and"},
            "query": {"params": ["A", "1m", "now"]},
            "reducer": {"params": [], "type": "last"},
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "1m",
        "frequency": "1m",
        "noDataState": "no_data"
      }
    }
  ]
}
