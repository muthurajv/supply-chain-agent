{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Mimir",
      "description": "Grafana Cloud Metrics (Mimir)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Logs (Loki)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "title": "Supply Chain Agent — Governance",
  "uid": "supply-chain-governance",
  "description": "Policy decision audit: approval rates, rule firing, cycle times, denied rationale (CLAUDE.md §12.2)",
  "tags": ["supply-chain", "governance", "policy"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "hide": 2,
        "current": {}
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "hide": 2,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Auto-Approval Rate (rolling 24 h) — target ≥ 80%",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Percentage of policy decisions that were auto-approved without human review.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 50},
              {"color": "green", "value": 80}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json | policy_outcome=\"auto_approved\" [24h])) / sum(count_over_time({service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json [24h])) * 100",
          "legendFormat": "Auto-approval %",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "alert": {
        "name": "Auto-approval rate < 50% for 1h",
        "conditions": [
          {
            "evaluator": {"params": [50], "type": "lt"},
            "operator": {"type": "and"},
            "query": {"params": ["A", "1h", "now"]},
            "reducer": {"params": [], "type": "last"},
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "1h",
        "frequency": "5m",
        "noDataState": "no_data"
      }
    },
    {
      "id": 2,
      "title": "Decisions by policy.outcome",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {
        "pieType": "donut",
        "legend": {"displayMode": "table", "placement": "right"},
        "displayLabels": ["percent"]
      },
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum by (policy_outcome) (count_over_time({service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json | policy_outcome != \"\" [$__range]))",
          "legendFormat": "{{policy_outcome}}",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rule Firing Frequency",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Which policy.rule_id fires most often. A single rule > 90% signals an over-broad rule.",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "orientation": "vertical",
        "xField": "policy_rule_id",
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "sum by (policy_rule_id) (count_over_time({service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json | policy_rule_id != \"\" [$__range]))",
          "legendFormat": "{{policy_rule_id}}",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Approval Cycle Time (p50)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Median time from proposal creation to human decision.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 3600},
              {"color": "red", "value": 86400}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(approval_cycle_duration_seconds_bucket{job=\"supply-chain-agent\"}[$__range])))",
          "legendFormat": "p50 cycle time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Denied Proposals",
      "type": "table",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 8},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Recent denied policy decisions with rule_id and turn for audit trail.",
      "fieldConfig": {
        "defaults": {"unit": "string"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.width", "value": 180}]},
          {"matcher": {"id": "byName", "options": "policy_rule_id"}, "properties": [{"id": "custom.width", "value": 120}]}
        ]
      },
      "options": {"showHeader": true},
      "targets": [
        {
          "expr": "{service_name=\"supply-chain-agent\", agent_name=\"policy\"} | json | policy_outcome=\"denied\"",
          "legendFormat": "",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "transformations": [
        {"id": "extractFields", "options": {"source": "labels"}},
        {"id": "organize", "options": {"excludeByName": {"__error__": true, "tsNs": true, "id": true}}}
      ]
    }
  ]
}
